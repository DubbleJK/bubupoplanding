# 카카오톡 플러스친구/채널 URL (문의 버튼 링크)
NEXT_PUBLIC_KAKAO_URL=https://pf.kakao.com/_xxxxx

# 전화번호 (하단 CTA·푸터)
# NEXT_PUBLIC_PHONE=010-0000-0000

# 푸터 등록번호·주소 (입력 시 하단 표시, 비우면 —)
# NEXT_PUBLIC_BUSINESS_REG_NO=000-00-00000
# NEXT_PUBLIC_BUSINESS_ADDRESS=○○시 ○○구 …

# 오시는 길 — 카카오맵 지도퍼가기(실행 스크립트의 timestamp, key)
# 코드에 기본값이 있어도, 배포 시 여기에 넣는 것을 권장합니다.
# NEXT_PUBLIC_KAKAO_ROUGHMAP_TIMESTAMP=1773851986777
# NEXT_PUBLIC_KAKAO_ROUGHMAP_KEY=j7btxafby4t
# NEXT_PUBLIC_MAP_URL= 카카오·네이버 지도 앱에서 열기 링크(선택)

# NEXT_PUBLIC_REPRESENTATIVE_NAME=홍길동

# 네이버 블로그 ID (메인 페이지 제작 사례에 최신글 표시)
# NAVER_BLOG_ID=
