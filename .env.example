# 실제 서비스 도메인 (OG·sitemap·robots URL에 사용, 커스텀 도메인 적용 후 반드시 맞추기)
# NEXT_PUBLIC_SITE_URL=https://www.example.com

# 카카오톡 플러스친구/채널 URL (문의 버튼 링크)
NEXT_PUBLIC_KAKAO_URL=https://pf.kakao.com/_xxxxx

# 전화번호 (하단 CTA·푸터)
# NEXT_PUBLIC_PHONE=010-0000-0000

# 푸터 등록번호·주소 (입력 시 하단 표시, 비우면 —)
# NEXT_PUBLIC_BUSINESS_REG_NO=000-00-00000
# NEXT_PUBLIC_BUSINESS_ADDRESS=○○시 ○○구 …

# 오시는 길 — 카카오맵 지도퍼가기(실행 스크립트의 timestamp, key)
# 코드에 기본값이 있어도, 배포 시 여기에 넣는 것을 권장합니다.
# NEXT_PUBLIC_KAKAO_ROUGHMAP_TIMESTAMP=1773851986777
# NEXT_PUBLIC_KAKAO_ROUGHMAP_KEY=j7btxafby4t
# NEXT_PUBLIC_MAP_URL= 카카오·네이버 지도 앱에서 열기 링크(선택)

# NEXT_PUBLIC_REPRESENTATIVE_NAME=홍길동

# 네이버 블로그 ID (메인 페이지 제작 사례에 최신글 표시)
# NAVER_BLOG_ID=

# 결제 완료 고객 전용 시안(/client-designs) — 월간 비밀번호(숫자 4자리) 자동 생성용 비밀 키
# CLIENT_DESIGNS_MASTER_SECRET=랜덤으로_길게_생성한_문자열

# /client-designs 페이지 「관리자용 페이지」— 마스터 PIN 입력 시 고객 월간 비밀번호 표시 + 시안 미리보기(4시간 쿠키)
# CLIENT_DESIGNS_ADMIN_PIN=

# (선택) 토큰 URL 관리자 페이지: /client-designs/admin?token=아래값
# CLIENT_DESIGNS_ADMIN_TOKEN=내부용_긴_토큰

# 시안 이미지: public/client-design-assets/ 폴더에 POSTER_A.webp 등으로 넣고 Git 커밋 후 배포 (웹 업로드 없음)
